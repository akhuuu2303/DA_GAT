DDG_CLIP_MIN, DDG_CLIP_MAX = -8.0, 6.0

# Amino Acid Mapping and Physicochemical Properties
AA_3TO1 = {'ALA':'A','CYS':'C','ASP':'D','GLU':'E','PHE':'F','GLY':'G',
           'HIS':'H','ILE':'I','LYS':'K','LEU':'L','MET':'M','ASN':'N',
           'PRO':'P','GLN':'Q','ARG':'R','SER':'S','THR':'T','VAL':'V',
           'TRP':'W','TYR':'Y','MSE':'M'}
AA_LIST = list('ACDEFGHIKLMNPQRSTVWY')
AA_TO_IDX = {aa: i for i, aa in enumerate(AA_LIST)}

HYDRO = {'A':1.8,'C':2.5,'D':-3.5,'E':-3.5,'F':2.8,'G':-0.4,'H':-3.2,
         'I':4.5,'K':-3.9,'L':3.8,'M':1.9,'N':-3.5,'P':-1.6,'Q':-3.5,
         'R':-4.5,'S':-0.8,'T':-0.7,'V':4.2,'W':-0.9,'Y':-1.3}
VOLUME = {'A':88.6,'C':108.5,'D':111.1,'E':138.4,'F':189.9,'G':60.1,'H':153.2,
          'I':166.7,'K':168.6,'L':166.7,'M':162.9,'N':114.1,'P':112.7,'Q':143.8,
          'R':173.4,'S':89.0,'T':116.1,'V':140.0,'W':227.8,'Y':193.6}
CHARGE = {'D':-1,'E':-1,'K':1,'R':1,'H':0.5}

# Part 2: Graph Construction Utilities
def download_pdb(pdb_id):
    path = os.path.join(PDB_DIR, f"{pdb_id}.pdb")
    if os.path.exists(path): return path
    try:
        r = requests.get(f"https://files.rcsb.org/download/{pdb_id}.pdb", timeout=30)
        if r.status_code == 200:
            with open(path, 'w') as f: f.write(r.text)
            return path
    except: pass
    return None

def get_ca_coordinates(pdb_path, chain):
    res = []; seen = set()
    with open(pdb_path) as f:
        for line in f:
            if not line.startswith('ATOM') or line[12:16].strip() != 'CA': continue
            if line[21].strip() != chain: continue
            rs, ic = int(line[22:26].strip()), line[26].strip()
            if (rs, ic) in seen: continue
            seen.add((rs, ic))
            aa = AA_3TO1.get(line[17:20].strip(), 'X')
            if aa == 'X': continue
            res.append({'aa': aa, 'coords': np.array([float(line[30:38]), float(line[38:46]), float(line[46:54])])})
    return res

def align_pdb_to_csv(pdb_res, csv_seq):
    ps = ''.join(r['aa'] for r in pdb_res)
    idx = csv_seq.find(ps)
    if idx >= 0: return [(idx + i, pdb_res[i]) for i in range(len(pdb_res))]
    bo, bn = 0, 0
    for o in range(max(0, len(csv_seq) - len(ps) + 1)):
        n = sum(1 for i in range(min(len(ps), len(csv_seq) - o)) if ps[i] == csv_seq[o + i])
        if n > bn: bn, bo = n, o
    if bn >= len(ps) * 0.8:
        return [(bo + i, pdb_res[i]) for i in range(min(len(ps), len(csv_seq) - bo)) if ps[i] == csv_seq[bo + i]]
    return None

def build_protein_graph(row, seq2emb, esm_dim=480):
    parts = row['name'].split('_')
    if parts[0] != 'rcsb' or len(parts) < 6: return None
    pdb_id, chain = parts[1].upper(), parts[2]
    wt_aa, mut_aa = parts[3][0], parts[3][-1]
    wt_seq, mut_seq = row['wt_seq'], row['mut_seq']
    ddG = row['ddG']
    pH, temp = float(parts[4]) if len(parts) > 4 else 7.0, float(parts[5]) if len(parts) > 5 else 25.0

    mut_seq_idx = next((i for i in range(min(len(wt_seq), len(mut_seq))) if wt_seq[i] != mut_seq[i]), None)
    if mut_seq_idx is None: return None

    pdb_path = download_pdb(pdb_id)
    if not pdb_path: return None
    pdb_res = get_ca_coordinates(pdb_path, chain)
    alignment = align_pdb_to_csv(pdb_res, wt_seq)
    if not alignment or len(alignment) < 10 or wt_seq not in seq2emb or mut_seq not in seq2emb: return None

    wt_emb, mut_emb = seq2emb[wt_seq], seq2emb[mut_seq]
    all_coords = np.array([a[1]['coords'] for a in alignment])
    mut_node = next((ni for ni, (si, _) in enumerate(alignment) if si == mut_seq_idx), None)
    if mut_node is None: return None

    mut_coords, dists_to_mut = all_coords[mut_node], np.linalg.norm(all_coords - all_coords[mut_node], axis=1)
    delta_hydro = (HYDRO.get(mut_aa, 0) - HYDRO.get(wt_aa, 0)) / 9.0
    delta_vol = (VOLUME.get(mut_aa, 130) - VOLUME.get(wt_aa, 130)) / 150.0
    delta_charge = CHARGE.get(mut_aa, 0) - CHARGE.get(wt_aa, 0)
    esm_delta_at_mut = (mut_emb[mut_seq_idx] - wt_emb[mut_seq_idx]).numpy() if mut_seq_idx < wt_emb.shape[0] else np.zeros(esm_dim)

    node_feats = []
    for ni, (si, pr) in enumerate(alignment):
        feat = np.concatenate([
            [AA_TO_IDX.get(pr['aa'], 0), 1.0 if ni == mut_node else 0.0, AA_TO_IDX.get(wt_aa, 0), AA_TO_IDX.get(mut_aa, 0),
             dists_to_mut[ni] / 20.0, pH / 14, temp / 100, delta_hydro, delta_vol, delta_charge],
            wt_emb[si].numpy() if si < wt_emb.shape[0] else np.zeros(esm_dim),
            esm_delta_at_mut
        ])
        node_feats.append(feat)

    dm = cdist(all_coords, all_coords)
    src, dst, ed, edir = [], [], [], []
    for i in range(len(alignment)):
        for j in range(len(alignment)):
            if i == j: continue
            d = dm[i, j]
            if d <= EDGE_CUTOFF:
                src.append(i); dst.append(j); ed.append(d / EDGE_CUTOFF)
                edir.append((all_coords[j] - all_coords[i]) / (d + 1e-8))

    return Data(x=torch.tensor(np.array(node_feats, dtype=np.float32)),
                edge_index=torch.tensor([src, dst], dtype=torch.long),
                edge_attr=torch.cat([torch.tensor(ed, dtype=torch.float32).unsqueeze(-1), 
                                    torch.tensor(np.array(edir), dtype=torch.float32)], 1),
                edge_dist=torch.tensor(ed, dtype=torch.float32),
                y=torch.tensor([ddG], dtype=torch.float32),
                mut_idx=torch.tensor([mut_node], dtype=torch.long),
                pdb_id=pdb_id)

# Part 3: Architecture Definitions
class DistanceKernel(nn.Module):
    def __init__(self, n_k=3):
        super().__init__()
        self.log_s = nn.Parameter(torch.log(torch.tensor([0.10, 0.25, 0.50])))
        self.w = nn.Parameter(torch.ones(n_k) / n_k)

    def forward(self, d):
        s = torch.exp(self.log_s)
        w = F.softmax(self.w, 0)
        return (torch.exp(-d.unsqueeze(-1)**2 / (2 * s**2 + 1e-8)) * w).sum(-1)

class DistanceGATLayer(MessagePassing):
    def __init__(self, in_ch, out_ch, heads=4, n_k=3, e_dim=4, drop=0.2, use_dist=True):
        super().__init__(aggr='add', node_dim=0)
        self.heads, self.out_ch, self.use_dist = heads, out_ch, use_dist
        self.W = nn.Linear(in_ch, heads * out_ch, bias=False)
        self.a_s = nn.Parameter(torch.zeros(1, heads, out_ch))
        self.a_d = nn.Parameter(torch.zeros(1, heads, out_ch))
        self.edge_proj = nn.Sequential(nn.Linear(e_dim, heads), nn.LeakyReLU(0.2))
        if use_dist:
            self.dk = DistanceKernel(n_k)
            self.gamma = nn.Parameter(torch.tensor(1.0))
        self.ln = nn.LayerNorm(heads * out_ch)
        self.lr = nn.LeakyReLU(0.2)
        nn.init.xavier_uniform_(self.W.weight)

    def forward(self, x, ei, ea, ed):
        H = self.W(x).view(-1, self.heads, self.out_ch)
        self._as, self._ad, self._H = (H * self.a_s).sum(-1), (H * self.a_d).sum(-1), H
        self._eb = self.edge_proj(ea)
        self._db = (self.gamma * self.dk(ed)).unsqueeze(-1) if self.use_dist else torch.zeros(ed.shape[0], 1, device=x.device)
        return self.ln(self.propagate(ei, size=None).view(-1, self.heads * self.out_ch))

    def message(self, edge_index_i, edge_index_j, size_i):
        a = softmax(self.lr(self._as[edge_index_i] + self._ad[edge_index_j] + self._eb + self._db), edge_index_i, num_nodes=size_i)
        return self._H[edge_index_j] * F.dropout(a, p=0.2, training=self.training).unsqueeze(-1)

class StabilityModel(nn.Module):
    def __init__(self, n_feat=970, hid=64, heads=4, drop=0.3, use_dist=True):
        super().__init__()
        self.drop = drop
        self.aa_emb = nn.Embedding(20, 32)
        gd = heads * hid
        self.proj = nn.Sequential(nn.Linear(32 + (n_feat - 1), gd), nn.LayerNorm(gd), nn.GELU(), nn.Dropout(drop))
        self.g1 = DistanceGATLayer(gd, hid, heads, use_dist=use_dist)
        self.g2 = DistanceGATLayer(gd, hid, heads, use_dist=use_dist)
        self.r1, self.r2 = nn.Linear(gd, gd), nn.Linear(gd, gd)
        self.reg = nn.Sequential(nn.Linear(gd * 2, 256), nn.GELU(), nn.Dropout(drop), nn.Linear(256, 1))

    def forward(self, data):
        x, ei, ea, ed, batch, mi = data.x, data.edge_index, data.edge_attr, data.edge_dist, data.batch, data.mut_idx
        x = torch.cat([self.aa_emb(x[:, 0].long().clamp(0, 19)), x[:, 1:]], 1)
        x = self.proj(x)
        x = F.gelu(self.g1(x, ei, ea, ed) + self.r1(x))
        x = F.gelu(self.g2(x, ei, ea, ed) + self.r2(x))
        bo = torch.zeros_like(mi)
        if batch is not None:
            for i in range(1, len(mi)): bo[i] = (batch < i).sum()
        return self.reg(torch.cat([x[mi.squeeze(-1) + bo], global_mean_pool(x, batch)], 1)).squeeze(-1)

# Part 4: Training and Evaluation Pipeline
def pearson_loss(pred, target):
    vp, vt = pred - pred.mean(), target - target.mean()
    r = (vp * vt).sum() / (torch.sqrt((vp**2).sum()) * torch.sqrt((vt**2).sum()) + 1e-8)
    return 1.0 - r

def weighted_huber_loss(pred, target, weights, delta=2.0):
    diff = torch.abs(pred - target)
    huber = torch.where(diff < delta, 0.5 * diff**2, delta * (diff - 0.5 * delta))
    return (huber * weights).mean()

def train_epoch(model, loader, opt, dev):
    model.train(); total_loss, n = 0, 0
    for batch in loader:
        batch = batch.to(dev); opt.zero_grad()
        pred, target = model(batch), batch.y.squeeze()
        weights = batch.sample_weight if hasattr(batch, 'sample_weight') else torch.ones_like(target)
        loss = weighted_huber_loss(pred, target, weights) + 0.5 * pearson_loss(pred, target)
        loss.backward(); torch.nn.utils.clip_grad_norm_(model.parameters(), 1.0); opt.step()
        total_loss += loss.item() * len(target); n += len(target)
    return total_loss / n

@torch.no_grad()
def evaluate(model, loader, dev):
    model.eval(); P, T = [], []
    for b in loader:
        b = b.to(dev); P.extend(model(b).cpu().numpy()); T.extend(b.y.squeeze().cpu().numpy())
    P, T = np.array(P), np.array(T)
    return {'pcc': pearsonr(T, P)[0], 'rmse': np.sqrt(mean_squared_error(T, P)), 'preds': P, 'targets': T}

# Part 5: Full Execution
if __name__ == "__main__":
    # Load and Preprocess Data
    train_df = pd.read_csv(os.path.join(RAW_DIR, 'S8754.csv'))
    test_df = pd.read_csv(os.path.join(RAW_DIR, 'S669.csv'))
    train_df['ddG'] = train_df['ddG'].clip(DDG_CLIP_MIN, DDG_CLIP_MAX)

    # ESM-2 Embedding Initialization
    ESM_NAME, ESM_DIM = "facebook/esm2_t12_35M_UR50D", 480
    esm_tok = EsmTokenizer.from_pretrained(ESM_NAME)
    esm_mdl = EsmModel.from_pretrained(ESM_NAME).to(device)
    esm_mdl.eval()

    all_seqs = set(train_df['wt_seq'].tolist() + train_df['mut_seq'].tolist() + 
                   test_df['wt_seq'].tolist() + test_df['mut_seq'].tolist())
    seq2emb = {}
    with torch.no_grad():
        for seq in sorted(all_seqs):
            inp = esm_tok(seq[:1022], return_tensors='pt', padding=False, truncation=True, max_length=1024).to(device)
            seq2emb[seq] = esm_mdl(**inp).last_hidden_state[0, 1:-1, :].cpu()
    del esm_mdl, esm_tok; torch.cuda.empty_cache(); gc.collect()

    # Graph Dataset Building
    train_graphs = [g for _, row in train_df.iterrows() if (g := build_protein_graph(row, seq2emb))]
    test_graphs = [g for _, row in test_df.iterrows() if (g := build_protein_graph(row, seq2emb))]
    del seq2emb; gc.collect()

    # Weighting and Splitting
    pdb_counts = Counter(g.pdb_id for g in train_graphs)
    for g in train_graphs: g.sample_weight = 1.0 / math.sqrt(pdb_counts[g.pdb_id])
    
    unique_pdbs = list(pdb_counts.keys())
    np.random.shuffle(unique_pdbs)
    val_set = set(unique_pdbs[:max(5, len(unique_pdbs) // 10)])
    actual_train = [g for g in train_graphs if g.pdb_id not in val_set]
    val_graphs = [g for g in train_graphs if g.pdb_id in val_set]

    # Experiment Loop
    trl, vl, tel = DataLoader(actual_train, 32, shuffle=True), DataLoader(val_graphs, 32), DataLoader(test_graphs, 32)
    m = StabilityModel(use_dist=True).to(device)
    opt = torch.optim.AdamW(m.parameters(), lr=2e-4, weight_decay=5e-4)
    sch = torch.optim.lr_scheduler.CosineAnnealingWarmRestarts(opt, 30, 2)
    
    best_pcc, best_state = -1, None
    for ep in range(150):
        train_epoch(m, trl, opt, device); vm = evaluate(m, vl, device); sch.step()
        if vm['pcc'] > best_pcc:
            best_pcc, best_state = vm['pcc'], {k: v.cpu().clone() for k, v in m.state_dict().items()}
    
    m.load_state_dict(best_state)
    results = evaluate(m, tel, device)
    print(f"S669 Final Result: Pearson r={results['pcc']:.4f}, RMSE={results['rmse']:.3f}")
